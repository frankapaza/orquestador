# ─── App ───────────────────────────────────────────────
NODE_ENV=production
PORT=3002

# ─── Base de datos ──────────────────────────────────────
DATABASE_URL=postgresql://kubo:CAMBIA_PASSWORD@localhost:5432/kubo_orquestador
DB_PASSWORD=CAMBIA_PASSWORD

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (usa un string largo y aleatorio) ──────────────
JWT_SECRET=CAMBIA_ESTE_SECRET_MINIMO_32_CARACTERES_ALEATORIOS
JWT_EXPIRES_IN=7d

# ─── URL pública del servidor ────────────────────────────
# La URL donde está desplegada la API (sin barra final)
# En VPS con IP: http://TU_IP:3002
# Con dominio:   https://tudominio.com
TRACKING_BASE_URL=https://tudominio.com

# URL que el navegador usará para llamar a la API
# Igual que TRACKING_BASE_URL pero con /api/v1 al final
NEXT_PUBLIC_API_URL=https://tudominio.com/api/v1

# ─── SMTP por defecto (opcional) ────────────────────────
SMTP_DEFAULT_HOST=
SMTP_DEFAULT_PORT=587
SMTP_DEFAULT_USER=
SMTP_DEFAULT_PASS=

# ─── Integraciones externas (opcional) ──────────────────
MAILCHIMP_API_KEY=
SENDGRID_API_KEY=
